# Laravel default ignores
/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.env.production
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log

# Custom strict ignores for RuangAiTi repository

# Exclude the entire agents and database folders
/.agents
/database
/tests
/Logobaru dan banner
/scratch
/temp_v2
/temp_roadmap_v2
/deploy_v6_temp
/uploads
/public/uploads

# Exclude SQL dumps and ZIP archives
*.sql
*.zip

# Exclude root files (keep only README.md and .gitignore)
/index.php
/artisan
/.editorconfig
/.gitattributes
/package.json
/composer.json
/composer.lock
/vite.config.js
/generate_static_sitemaps.php
/sitemap.xml
/google*.html
/site.webmanifest
/favicon.ico
/favicon-*.png
/apple-touch-icon.png
/android-chrome-*.png

